# Copy to .env.local for local dev, OR set these in your host's dashboard (Vercel).

# --- Required ---
# Get a free key at: https://data.uspto.gov/apis/getting-started
USPTO_API_KEY=your-uspto-api-key-here

# Secures the daily cron route. Generate with: openssl rand -base64 32
CRON_SECRET=your-random-secret-here

# Auto-injected by the Vercel Postgres integration (don't set by hand in prod):
# POSTGRES_URL=postgres://...

# --- Optional: email digests (Resend) ---
# Leave unset to use in-app alerts only. https://resend.com
RESEND_API_KEY=
DIGEST_FROM=USPTO Watch <alerts@yourdomain.com>
DIGEST_TO=you@example.com
# Override the site URL used for download links in emails (otherwise auto-detected):
# APP_BASE_URL=https://your-project.vercel.app
