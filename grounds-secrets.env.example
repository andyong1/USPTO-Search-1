# Copy this file to grounds-secrets.env (which is gitignored) and fill in both
# values. Used by grounds-topup.sh / the scheduled top-up task.
#
#   POSTGRES_URL  Neon connection string — Vercel dashboard -> Storage -> Neon ->
#                 .env.local tab. RECOMMENDED: create a Neon role scoped to only
#                 the grounds tables (reexam_doc_text) instead of the full-access
#                 string, so an exposed file has limited blast radius.
#   CRON_SECRET   the value already set in Vercel (used to auth the backfill crons).
#
POSTGRES_URL=
CRON_SECRET=
